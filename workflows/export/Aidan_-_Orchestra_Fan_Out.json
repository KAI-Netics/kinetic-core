                      "name":  "Orchestra Trigger",
                      "webhookId":  "aidan-orchestra-trigger"
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const fs = require(\u0027fs\u0027), http = require(\u0027http\u0027);\nconst raw = $input.first().json;\nconst body = raw.body || raw;\n\n// If this is an agent callback, save it and exit — do NOT fan out\nif (body.agent \u0026\u0026 [\u0027Scout\u0027,\u0027Jordan\u0027,\u0027Iris\u0027,\u0027Atlas\u0027,\u0027Nova\u0027,\u0027Sage\u0027,\u0027Pulse\u0027].includes(body.agent)) {\n  fs.mkdirSync(\u0027/data/Aidan_Outputs/Callbacks\u0027, { recursive: true });\n  const ts = body.timestamp || new Date().toISOString();\n  fs.writeFileSync(`/data/Aidan_Outputs/Callbacks/${body.agent}_${ts.replace(/[:.]/g,\u0027-\u0027)}.json`, JSON.stringify(body, null, 2), \u0027utf8\u0027);\n  return [{ json: { _isCallback: true, agent: body.agent, saved: true } }];\n}\n\nconst masterQuery = String(body.query || body.command || \u0027Full platform status — compliance, BD targets, grant status, MEIA readiness.\u0027);\nconst sessionId = \u0027orch_\u0027 + Date.now();\nfs.mkdirSync(\u0027/data/Aidan_Outputs/Orchestra\u0027, { recursive: true });\nfs.writeFileSync(`/data/Aidan_Outputs/Orchestra/session_${sessionId}.json`, JSON.stringify({ sessionId, masterQuery, startTime: new Date().toISOString(), agents: { Atlas: null, Scout: null, Jordan: null, Iris: null } }, null, 2), \u0027utf8\u0027);\n\nconst agentCalls = [\n  { path: \u0027/webhook/atlas-architect\u0027, payload: { command: \u0027Atlas status\u0027, detail: masterQuery, sessionId } },\n  { path: \u0027/webhook/scout-research\u0027, payload: { query: masterQuery + \u0027 — top 3 DMV contract opportunities\u0027, sessionId } },\n  { path: \u0027/webhook/grant-writer\u0027, payload: { trigger: \u0027orchestra\u0027, query: masterQuery, sessionId } },\n  { path: \u0027/webhook/iris-monitor\u0027, payload: { trigger: \u0027orchestra\u0027, sessionId } }\n];\n\nconst fireAgent = (agentPath, payload) =\u003e new Promise(resolve =\u003e {\n  const bodyStr = JSON.stringify(payload);\n  const opts = { hostname: \u0027host.docker.internal\u0027, port: 5678, path: agentPath, method: \u0027POST\u0027, headers: { \u0027Content-Type\u0027: \u0027application/json\u0027, \u0027Content-Length\u0027: Buffer.byteLength(bodyStr) } };\n  const req = http.request(opts, res =\u003e { res.on(\u0027data\u0027,()=\u003e{}); res.on(\u0027end\u0027, () =\u003e resolve({ path: agentPath, fired: true })); });\n  req.on(\u0027error\u0027, e =\u003e resolve({ path: agentPath, fired: false, error: e.message }));\n  req.write(bodyStr); req.end();\n});\n\nconst results = await Promise.all(agentCalls.map(a =\u003e fireAgent(a.path, a.payload)));\nconst agentNames = [\u0027Atlas\u0027,\u0027Scout\u0027,\u0027Jordan\u0027,\u0027Iris\u0027];\nconst launchMsg = `🎼 ORCHESTRA LAUNCHED\\n\\n${agentNames.map((a,i) =\u003e `${results[i].fired?\u0027✅\u0027:\u0027❌\u0027} ${a}`).join(\u0027\\n\u0027)}\\n\\nQuery: ${masterQuery.substring(0,80)}\\n\\nConsolidated brief incoming ~90 seconds.`;\n\nconst msgBody = JSON.stringify({ number: \u002714432576836@s.whatsapp.net\u0027, textMessage: { text: launchMsg } });\nconst waOpts = { hostname: \u0027host.docker.internal\u0027, port: 8081, path: \u0027/message/sendText/Aidan\u0027, method: \u0027POST\u0027, headers: { \u0027Content-Type\u0027: \u0027application/json\u0027, \u0027apikey\u0027: \u0027Kevin2026\u0027, \u0027Content-Length\u0027: Buffer.byteLength(msgBody) } };\nawait new Promise(r =\u003e { const req = http.request(waOpts, res =\u003e { res.on(\u0027data\u0027,()=\u003e{}); res.on(\u0027end\u0027,r); }); req.on(\u0027error\u0027,r); req.write(msgBody); req.end(); });\n\nreturn [{ json: { sessionId, masterQuery, results, launched: true } }];"
                                     },
